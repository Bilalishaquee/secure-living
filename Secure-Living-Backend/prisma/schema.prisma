generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum VerificationLevel {
  UNVERIFIED         // 0 – account only
  IDENTITY_VERIFIED  // 1 – Didit.me face match
  COMPLIANCE_VERIFIED // 2 – IPRS confirmed
  TRUSTED_PERSONNEL  // 3 – Good Conduct + history
  ENTERPRISE_VERIFIED // 4 – agency/business full review
}

enum FreezeType {
  SOFT // prevents new listings & SR creation
  HARD // hides listings, suspends account
}

enum FreezeStatus {
  ACTIVE
  LIFTED
  EXPIRED
}

enum AppealStatus {
  SUBMITTED
  UNDER_REVIEW
  UPHELD
  OVERTURNED
}

enum UtilityType {
  WATER
  ELECTRICITY
}

enum BillingModel {
  FLAT_RATE
  SUB_METERED_MANUAL
  SUB_METERED_IOT
}

enum AllocationMethod {
  PRO_RATA
  FLAT_AMOUNT
}

enum DisputeStatus {
  OPEN
  LANDLORD_RESPONDED
  ESCALATED
  RESOLVED_ACCEPTED
  RESOLVED_REJECTED
}

enum DepositTransferStatus {
  LISTED
  BUYER_PAID
  LANDLORD_APPROVED
  INSPECTION_COMPLETE
  RELEASED
  EXPIRED
  CANCELLED
}

enum PackageTier {
  FREE
  LISTING_ONLY
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
  CUSTOM
}

enum TrustedPersonnelStatus {
  PENDING
  APPROVED
  DENIED
  REVOKED
}

enum DocumentRequestEnforcement {
  REMINDER
  SOFT_FREEZE
  HARD_FREEZE
}

enum DocumentRequestStatus {
  PENDING
  UPLOADED
  APPROVED
  REJECTED
  EXPIRED
}

enum ContainerType {
  STANDALONE
  ESTATE
  COMPLEX
  COURTYARD
  MALL
}

enum VacatingStatus {
  PENDING
  ACKNOWLEDGED
  INSPECTION_SCHEDULED
  INSPECTION_DONE
  DEPOSIT_PROCESSING
  COMPLETED
}

enum InspectionStatus {
  PROPOSED
  ACCEPTED
  RESCHEDULED
  COMPLETED
}

enum RefundStatus {
  PENDING
  APPROVED
  PAID
  DISPUTED
}

enum ChecklistType {
  MOVE_IN
  MOVE_OUT
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  UNDER_OFFER
  LET
  WITHDRAWN
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  ACCEPTED
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

// ─── Phase 3 Enums ────────────────────────────────────────────────────────────

enum ServiceRequestType {
  MAINTENANCE
  INSPECTION
  LEGAL
  PROXY
  VALUATION
  CLEANING
  FOOD_DELIVERY
  AIRPORT_TRANSFER
  GUEST_ASSISTANCE
  CUSTOM
}

enum SrStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  QUOTING
  AWAITING_FUNDING
  FUNDED
  ASSIGNED
  SCHEDULING_PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum SrPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ServiceMode {
  MANAGED
  MARKETPLACE
  INTERNAL
}

enum SrCategory {
  OPERATIONAL
  GUEST_SERVICE
  EMERGENCY
}

enum BlockedReasonType {
  AWAITING_LANDLORD_APPROVAL
  TENANT_UNAVAILABLE
  PROVIDER_UNAVAILABLE
  MISSING_MATERIALS
  LEGAL_DEPENDENCY
  PAYMENT_PENDING
  WEATHER_ACCESS_ISSUE
  OTHER
}

enum RequestSource {
  MOBILE_APP
  WHATSAPP
  QR_CODE
  WEB_PORTAL
  RECEPTION
  IN_ROOM_TABLET
  TELEPHONE
}

enum ProviderCategory {
  INTERNAL
  VERIFIED_MARKETPLACE
  LANDLORD_PREFERRED
  AGENCY_PREFERRED
  TENANT_REFERRED
}

enum ProviderStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
  BLACKLISTED
  REJECTED
}

enum QuoteStatus {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

enum UnitReadiness {
  PENDING_CLEAN
  PENDING_INSPECTION
  READY
  BLOCKED
}

// ─── Container Hierarchy ──────────────────────────────────────────────────────

model Container {
  id             String        @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  type           ContainerType
  description    String?
  address        String?
  city           String?
  country        String?
  coverImage     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  properties   Property[]
  managers     ContainerManager[]

  @@index([organizationId])
}

model ContainerManager {
  id          String   @id @default(cuid())
  containerId String
  userId      String
  role        String
  assignedAt  DateTime @default(now())

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)
  user      AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([containerId])
  @@index([userId])
}

// ─── Vacating & Move-Out Workflow ─────────────────────────────────────────────

model VacatingNotice {
  id               String         @id @default(cuid())
  leaseId          String         @unique
  unitId           String
  tenantId         String
  organizationId   String
  noticeDate       DateTime       @default(now())
  intendedMoveOut  DateTime
  enforcedMoveOut  DateTime
  noticePeriodDays Int            @default(30)
  status           VacatingStatus @default(PENDING)
  tenantNote       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  lease         Lease              @relation(fields: [leaseId], references: [id])
  unit          Unit               @relation(fields: [unitId], references: [id])
  inspection    MoveOutInspection?
  depositRefund DepositRefund?

  @@index([organizationId, status])
  @@index([unitId])
  @@index([tenantId])
}

model MoveOutInspection {
  id               String           @id @default(cuid())
  vacatingNoticeId String           @unique
  organizationId   String
  scheduledDate    DateTime
  status           InspectionStatus @default(PROPOSED)
  inspectedBy      String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  vacatingNotice VacatingNotice        @relation(fields: [vacatingNoticeId], references: [id])
  deductions     InspectionDeduction[]

  @@index([organizationId])
}

model InspectionDeduction {
  id           String   @id @default(cuid())
  inspectionId String
  description  String
  amount       Float
  photoUrl     String?
  createdAt    DateTime @default(now())

  inspection MoveOutInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model DepositRefund {
  id               String       @id @default(cuid())
  vacatingNoticeId String       @unique
  organizationId   String
  depositAmount    Float
  totalDeductions  Float        @default(0)
  refundAmount     Float
  status           RefundStatus @default(PENDING)
  voucherNumber    String?
  paidAt           DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  vacatingNotice VacatingNotice @relation(fields: [vacatingNoticeId], references: [id])

  @@index([organizationId, status])
}

// ─── Move-In Checklist ────────────────────────────────────────────────────────

model ChecklistTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items            ChecklistTemplateItem[]
  tenantChecklists TenantChecklist[]

  @@index([organizationId])
}

model ChecklistTemplateItem {
  id         String @id @default(cuid())
  templateId String
  section    String
  item       String
  order      Int

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

model TenantChecklist {
  id         String        @id @default(cuid())
  leaseId    String
  unitId     String
  tenantId   String
  templateId String
  type       ChecklistType
  status     String        @default("PENDING")
  signedAt   DateTime?
  createdAt  DateTime      @default(now())

  lease    Lease                 @relation(fields: [leaseId], references: [id])
  unit     Unit                  @relation(fields: [unitId], references: [id])
  template ChecklistTemplate     @relation(fields: [templateId], references: [id])
  entries  TenantChecklistEntry[]

  @@index([leaseId])
  @@index([unitId])
  @@index([tenantId])
}

model TenantChecklistEntry {
  id          String  @id @default(cuid())
  checklistId String
  itemId      String
  condition   String
  note        String?
  photoUrl    String?

  checklist TenantChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

// ─── Listing Module ───────────────────────────────────────────────────────────

model Listing {
  id             String        @id @default(cuid())
  organizationId String
  unitId         String        @unique
  title          String
  description    String?
  rentAmount     Float
  currency       String        @default("KES")
  availableFrom  DateTime
  leaseDuration  String?
  furnished      Boolean       @default(false)
  petFriendly    Boolean       @default(false)
  features       String[]
  photos         String[]
  status         ListingStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  unit         Unit               @relation(fields: [unitId], references: [id])
  applications RentalApplication[]

  @@index([organizationId, status])
}

model RentalApplication {
  id          String            @id @default(cuid())
  listingId   String
  applicantId String
  message     String?
  status      ApplicationStatus @default(PENDING)
  submittedAt DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
}

// ─── Accounting Enhancements ──────────────────────────────────────────────────

model MonthlyRentSummary {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  periodYear     Int
  periodMonth    Int
  openingBalance Float    @default(0)
  totalRentDue   Float    @default(0)
  totalCollected Float    @default(0)
  totalArrears   Float    @default(0)
  closingBalance Float    @default(0)
  totalExpenses  Float    @default(0)
  notes          String?
  generatedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, periodYear, periodMonth])
  @@index([organizationId])
}

// ─── Role Context ─────────────────────────────────────────────────────────────

model UserRoleContext {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  containerId    String?
  role           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

// ─── Supporting Services ──────────────────────────────────────────────────────

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  tagline     String?
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enquiries ServiceEnquiry[]

  @@index([isActive, order])
}

model ServiceEnquiry {
  id                String        @id @default(cuid())
  organizationId    String?
  userId            String?
  serviceCategoryId String
  name              String
  email             String
  phone             String?
  message           String
  status            EnquiryStatus @default(NEW)
  assignedTo        String?
  assignedAt        DateTime?
  resolvedAt        DateTime?
  internalNotes     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  @@index([serviceCategoryId, status])
  @@index([status, createdAt])
}

// ─── Airbnb / Short-Stay Module ───────────────────────────────────────────────

model ShortStayProperty {
  id             String   @id @default(cuid())
  unitId         String   @unique
  organizationId String
  checkInTime    String   @default("14:00")
  checkOutTime   String   @default("11:00")
  nightlyRate    Float
  currency       String   @default("KES")
  cleaningFee    Float    @default(0)
  minNights      Int      @default(1)
  maxNights      Int      @default(30)
  houseRules     String?
  wifiPassword   String?
  accessNotes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  unit     Unit               @relation(fields: [unitId], references: [id])
  bookings ShortStayBooking[]
  stock    StockItem[]

  @@index([organizationId])
}

model ShortStayBooking {
  id              String        @id @default(cuid())
  shortStayId     String
  organizationId  String
  guestName       String
  guestEmail      String
  guestPhone      String?
  guestIdNumber   String?
  checkInDate     DateTime
  checkOutDate    DateTime
  checkInTime     String?
  checkOutTime    String?
  numberOfGuests  Int           @default(1)
  totalAmount     Float
  amountPaid      Float         @default(0)
  status          BookingStatus @default(CONFIRMED)
  specialRequests String?
  internalNotes   String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shortStay  ShortStayProperty  @relation(fields: [shortStayId], references: [id])
  stockUsage BookingStockUsage[]

  @@index([shortStayId, status])
  @@index([organizationId, checkInDate])
}

model StockItem {
  id              String   @id @default(cuid())
  shortStayId     String
  name            String
  unit            String
  unitCost        Float
  quantityInStock Int      @default(0)
  reorderLevel    Int      @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shortStay ShortStayProperty  @relation(fields: [shortStayId], references: [id])
  usages    BookingStockUsage[]

  @@index([shortStayId])
}

model BookingStockUsage {
  id          String @id @default(cuid())
  bookingId   String
  stockItemId String
  quantity    Int
  totalCost   Float

  booking   ShortStayBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stockItem StockItem        @relation(fields: [stockItemId], references: [id])

  @@index([bookingId])
}

// ─── Existing Core Models ─────────────────────────────────────────────────────

model ServiceRequest {
  id               String              @id @default(cuid())
  organizationId   String
  branchId         String
  propertyId       String?
  unitId           String?
  tenantUserId     String?
  assignedToUserId String?
  // Legacy string field kept for backward compat
  type             String              @default("maintenance")
  title            String
  description      String
  category         String
  priority         String
  estimatedCostKes Float?
  actualCostKes    Float?
  scheduledDate    DateTime?
  completedDate    DateTime?
  notes            String?
  evidenceUrlsCsv  String?
  status           String              @default("DRAFT")
  escalatedAt      DateTime?
  escalatedReason  String?
  approvedAt       DateTime?
  createdBy        String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  closedAt         DateTime?

  // Phase 3 fields
  serviceType           ServiceRequestType  @default(MAINTENANCE)
  serviceMode           ServiceMode         @default(MARKETPLACE)
  srCategory            SrCategory          @default(OPERATIONAL)
  srStatus              SrStatus            @default(DRAFT)
  srPriority            SrPriority          @default(NORMAL)
  requestSource         RequestSource       @default(MOBILE_APP)
  blockedReasonType     BlockedReasonType?
  blockedReason         String?
  idempotencyKey        String?             @unique
  metadata              Json?
  internalNotes         String?
  rejectionReason       String?
  disputeReason         String?
  resolutionNotes       String?
  startedAt             DateTime?
  dueAt                 DateTime?
  resolvedAt            DateTime?
  // SLA tracking
  activeWorkDurationSec Int                 @default(0)
  blockedDurationSec    Int                 @default(0)
  waitingForClientSec   Int                 @default(0)
  waitingForProviderSec Int                 @default(0)
  slaPolicyId           String?
  // Short-stay / hospitality
  shortStayBookingId    String?
  guestId               String?
  bookingCheckInAt      DateTime?
  bookingCheckOutAt     DateTime?
  turnaroundDeadline    DateTime?
  guestAvailabilityWindow String?
  // Payment
  paymentStatus         String              @default("PENDING")
  paymentResponsibility String              @default("MANAGEMENT")
  serviceChargeAmount   Float?

  jobAssignments  JobAssignment[]
  evidences       ServiceRequestEvidence[]
  srHistory       ServiceRequestHistory[]
  srAssignments   ServiceRequestAssignment[]
  escalations     ServiceRequestEscalation[]
  quotes          ServiceRequestQuote[]
  outboxEvents    OutboxEvent[]

  @@index([organizationId, branchId, status])
  @@index([organizationId, branchId, srStatus])
  @@index([propertyId, unitId])
  @@index([serviceType, srStatus])
  @@index([shortStayBookingId])
}

model ServiceRequestEvidence {
  id               String   @id
  serviceRequestId String
  uploadedByUserId String
  mediaType        String
  fileName         String
  mimeType         String
  filePath         String
  fileSizeBytes    Int
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId, createdAt])
}

model Lease {
  id               String    @id
  organizationId   String
  branchId         String
  propertyId       String
  unitId           String
  tenantUserId     String
  leaseType        String
  rentAmount       Float
  depositAmount    Float?
  startDate        DateTime
  endDate          DateTime
  paymentFrequency String
  status           String
  signedAt         DateTime?
  terminatedAt     DateTime?
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rentInvoices     RentInvoice[]
  vacatingNotice   VacatingNotice?
  tenantChecklists TenantChecklist[]
}

model ProfessionalProfile {
  id                 String   @id
  userId             String
  organizationId     String?
  branchId           String?
  profession         String
  skillsCsv          String
  rating             Float    @default(0)
  verificationStatus String
  bio                String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([organizationId, branchId, isActive])
}

model JobAssignment {
  id                 String         @id
  serviceRequestId   String
  professionalUserId String
  assignmentStatus   String
  quotedAmount       Float?
  agreedAmount       Float?
  assignedBy         String
  assignedAt         DateTime       @default(now())
  acceptedAt         DateTime?
  completedAt        DateTime?
  notes              String?
  ServiceRequest     ServiceRequest @relation(fields: [serviceRequestId], references: [id])

  @@index([serviceRequestId, professionalUserId])
}

model AuditLog {
  id           String   @id
  userId       String
  role         String
  action       String
  resourceType String
  resourceId   String
  branchId     String?
  orgId        String?
  beforeJson   String?
  afterJson    String?
  timestamp    DateTime @default(now())
}

model Wallet {
  id         String   @id
  ownerId    String
  ownerType  String
  walletType String
  currency   String   @default("KES")
  isFrozen   Boolean  @default(false)
  createdAt  DateTime @default(now())

  fromTransactions Transaction[] @relation("transaction_from_wallet")
  toTransactions   Transaction[] @relation("transaction_to_wallet")
  ledgerEntries    LedgerEntry[]
  fundHolds        FundHold[]

  @@index([ownerType, ownerId, walletType])
}

model LedgerEntry {
  id                String   @id
  walletId          String
  transactionId     String?
  entryType         String
  amountKes         Float
  runningBalanceKes Float?
  description       String?
  referenceId       String?
  referenceType     String?
  createdAt         DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([transactionId])
}

model Transaction {
  id                    String    @id
  organizationId        String?
  propertyId            String?
  unitId                String?
  fromWalletId          String?
  toWalletId            String?
  amountKes             Float
  feeKes                Float     @default(0)
  netKes                Float
  transactionType       String
  paymentMethod         String
  mpesaReference        String?
  bankReference         String?
  idempotencyKey        String?
  status                String
  description           String?
  metadataJson          String?
  createdAt             DateTime  @default(now())
  reversedAt            DateTime?
  reversalTransactionId String?

  fromWallet Wallet? @relation("transaction_from_wallet", fields: [fromWalletId], references: [id], onDelete: SetNull)
  toWallet   Wallet? @relation("transaction_to_wallet", fields: [toWalletId], references: [id], onDelete: SetNull)

  @@unique([idempotencyKey])
  @@index([organizationId, propertyId, transactionType, createdAt])
}

model IdempotencyKey {
  key          String    @id
  requestHash  String
  responseJson String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
}

model EscrowAccount {
  id         String    @id
  leaseId    String
  tenantId   String
  landlordId String
  propertyId String
  unitId     String
  amountKes  Float
  status     String
  heldAt     DateTime?
  releasedAt DateTime?
  disputeId  String?
  createdAt  DateTime  @default(now())

  @@index([leaseId, status])
}

model FundHold {
  id               String    @id
  walletId         String
  amountKes        Float
  reason           String
  heldByUserId     String
  releasedByUserId String?
  isActive         Boolean   @default(true)
  heldAt           DateTime  @default(now())
  releasedAt       DateTime?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model RentInvoice {
  id              String    @id
  leaseId         String
  tenantId        String
  landlordId      String
  propertyId      String
  unitId          String
  invoiceNumber   String    @unique
  periodStart     DateTime
  periodEnd       DateTime
  dueDate         DateTime
  rentAmountKes   Float
  lateFeeKes      Float     @default(0)
  otherChargesKes Float     @default(0)
  totalDueKes     Float
  amountPaidKes   Float     @default(0)
  balanceKes      Float
  status          String
  paymentMethod   String?
  mpesaReference  String?
  sentAt          DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  Lease           Lease     @relation(fields: [leaseId], references: [id])

  @@index([leaseId, dueDate, status])
}

model ReconciliationReport {
  id             String    @id
  runAt          DateTime  @default(now())
  periodStart    DateTime
  periodEnd      DateTime
  expectedKes    Float
  actualKes      Float
  discrepancyKes Float
  status         String
  resolvedAt     DateTime?
}

model Unit {
  id               String   @id
  organizationId   String
  branchId         String
  propertyId       String
  unitNumber       String
  floor            String?
  unitType         String
  category         String   @default("residential")
  bedrooms         Int?
  bathrooms        Float?
  sizeSqft         Float?
  rentAmountKes    Float?
  depositAmountKes Float?
  isFurnished      Boolean  @default(false)
  amenitiesCsv     String?
  parkingBay       String?
  specialNotes     String?
  status           String
  currentTenantId  String?
  currentLeaseId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  readinessStatus  UnitReadiness     @default(READY)

  vacatingNotices  VacatingNotice[]
  tenantChecklists TenantChecklist[]
  shortStayProperty ShortStayProperty?
  listing          Listing?

  @@index([organizationId, branchId, propertyId, status])
  @@index([readinessStatus])
}

model Property {
  id                        String    @id
  organizationId            String
  branchId                  String
  containerId               String?
  ownerUserId               String?
  managerUserId             String?
  name                      String
  propertyCode              String?
  propertyType              String
  ownershipType             String?
  addressLine1              String
  addressLine2              String?
  county                    String?
  subCounty                 String?
  ward                      String?
  city                      String?
  state                     String?
  country                   String
  postalCode                String?
  gpsLatitude               Float?
  gpsLongitude              Float?
  landReferenceNumber       String?
  titleDeedNumber           String?
  descriptionNotes          String?
  yearBuilt                 Int?
  totalUnits                Int?
  totalSqft                 Float?
  lotSizeSqft               Float?
  totalBathrooms            Float?
  totalParkingSpaces        Int?
  purchasePriceKes          Float?
  acquisitionDate           DateTime?
  currentValueKes           Float?
  mortgageBalanceKes        Float?
  marketRentEstimateKes     Float?
  noiEstimateKes            Float?
  capRateEstimate           Float?
  propertyTaxAnnualKes      Float?
  insuranceProvider         String?
  insurancePremiumAnnualKes Float?
  insurancePolicyNumber     String?
  insuranceExpiryDate       DateTime?
  hoaFeeMonthlyKes          Float?
  mortgageLender            String?
  mortgageInterestRate      Float?
  mortgageLoanTermMonths    Int?
  mortgageMonthlyPaymentKes Float?
  mortgageStartDate         DateTime?
  mortgageMaturityDate      DateTime?
  listingUrl                String?
  shortTermRentalPlatform   String?
  tagsCsv                   String?
  amenitiesCsv              String?
  photosCsv                 String?
  videosCsv                 String?
  floorPlanUrl              String?
  titleDeedScanUrl          String?
  category                  String   @default("residential")
  managementMode            String   @default("self_managed")
  categoryAttributesJson    String?
  status                    String
  createdBy                 String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  container       Container?               @relation(fields: [containerId], references: [id])
  roleAssignments PropertyRoleAssignment[]

  @@index([organizationId, branchId, status])
  @@index([propertyType])
  @@index([containerId])
}

model Organization {
  id        String   @id
  name      String
  type      String
  country   String
  email     String
  phone     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches        Branch[]
  roleAssignments UserRoleAssignment[]
  containers      Container[]

  @@index([status])
}

model Branch {
  id             String   @id
  organizationId String
  name           String
  location       String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleAssignments UserRoleAssignment[]

  @@index([organizationId, status])
}

model AppUser {
  id                    String            @id
  email                 String            @unique
  passwordHash          String
  fullName              String
  phone                 String?
  status                String            @default("active")
  // Verification
  verificationLevel     VerificationLevel @default(UNVERIFIED)
  verificationLevelSetAt DateTime?
  diditSessionId        String?
  iprsCheckedAt         DateTime?
  iprsResult            String?
  // Level 3 – Trusted Personnel
  trustedPersonnelStatus TrustedPersonnelStatus?
  goodConductUploadedAt  DateTime?
  goodConductExpiresAt   DateTime?
  trustedPersonnelReviewedAt DateTime?
  trustedPersonnelReviewedBy String?
  // Fraud scoring (internal, never shown to user)
  fraudScore            Int               @default(0)
  // Deferred: QR token (Phase 4 – do not expose endpoint yet)
  qrToken               String?
  qrTokenRotatedAt      DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  sessions             ApiSession[]
  roleAssignments      UserRoleAssignment[]
  kycDocuments         KycDocument[]
  containerManagements ContainerManager[]
  roleContexts         UserRoleContext[]
  accountFreezes       AccountFreeze[]
  freezeAppeals        FreezeAppeal[]
  documentRequests     UserDocumentRequest[]
}

model Role {
  id          String   @id
  slug        String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions     RolePermission[]
  userAssignments UserRoleAssignment[]
}

model Permission {
  id          String   @id
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  id           String   @id
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRoleAssignment {
  id             String   @id
  userId         String
  roleId         String
  organizationId String
  branchId       String
  status         String   @default("active")
  createdAt      DateTime @default(now())

  user         AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([organizationId, branchId])
}

model ApiSession {
  token     String    @id
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model KycDocument {
  id               String    @id
  userId           String
  organizationId   String?
  branchId         String?
  documentType     String
  fileName         String
  mimeType         String
  filePath         String
  fileSizeBytes    Int
  status           String    @default("pending")
  uploadedAt       DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?
  rejectionReason  String?

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, uploadedAt])
}

model PropertyRoleAssignment {
  id         String   @id
  propertyId String
  userId     String
  roleType   String
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, roleType])
  @@index([userId, roleType])
}

model Expense {
  id             String    @id
  organizationId String
  branchId       String
  propertyId     String
  unitId         String?
  category       String
  description    String
  amountKes      Float
  date           DateTime
  vendorName     String?
  receiptUrl     String?
  paymentMethod  String?
  isRecurring    Boolean   @default(false)
  recurringFreq  String?
  notes          String?
  createdBy      String
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, branchId, propertyId, date])
  @@index([category, date])
}

model FinancialReport {
  id              String   @id
  organizationId  String
  branchId        String
  propertyId      String?
  reportType      String
  periodStart     DateTime
  periodEnd       DateTime
  totalIncomeKes  Float
  totalExpenseKes Float
  netKes          Float
  reportJson      String
  generatedBy     String
  createdAt       DateTime @default(now())

  @@index([organizationId, propertyId, reportType, periodStart])
}

model LeaseRenewalAlert {
  id           String    @id
  leaseId      String
  propertyId   String
  unitId       String
  tenantUserId String
  expiryDate   DateTime
  alertSentAt  DateTime?
  status       String
  createdAt    DateTime  @default(now())

  @@index([expiryDate, status])
}

model SubscriptionPlan {
  id              String   @id
  code            String   @unique
  name            String
  priceKesMonthly Float
  priceKesAnnual  Float?
  featureJson     String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model UserSubscription {
  id             String    @id
  userId         String
  organizationId String?
  planCode       String
  status         String
  billingCycle   String
  startedAt      DateTime
  nextBillingAt  DateTime?
  canceledAt     DateTime?
  createdAt      DateTime  @default(now())
}

model TenantScreeningReport {
  id               String   @id
  applicationId    String
  applicantName    String
  nationalIdNumber String?
  score            Int?
  recommendation   String
  riskFlagsJson    String?
  notes            String?
  status           String
  generatedBy      String
  createdAt        DateTime @default(now())
}

model DocumentTemplate {
  id           String   @id
  name         String
  category     String
  jurisdiction String
  templateBody String
  variablesCsv String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ESignRequest {
  id           String    @id
  templateId   String?
  leaseId      String?
  title        String
  documentUrl  String?
  signerUserId String
  signerEmail  String
  status       String
  sentAt       DateTime?
  signedAt     DateTime?
  expiresAt    DateTime?
  createdBy    String
  createdAt    DateTime  @default(now())
}

model ReminderSchedule {
  id                 String   @id
  organizationId     String?
  branchId           String?
  targetType         String
  targetId           String
  channel            String
  scheduleOffsetDays Int
  messageTemplate    String
  isEnabled          Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model TeamInvitation {
  id              String    @id
  organizationId  String
  branchId        String
  invitedByUserId String
  inviteeEmail    String
  roleSlug        String
  propertyIdsCsv  String?
  status          String    @default("pending")
  inviteToken     String    @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([organizationId, status])
  @@index([inviteeEmail])
}

// ─── Phase 3 Models ───────────────────────────────────────────────────────────

model ServiceRequestHistory {
  id               String    @id @default(cuid())
  serviceRequestId String
  changedBy        String
  fromStatus       SrStatus
  toStatus         SrStatus
  note             String?
  changedAt        DateTime  @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId, changedAt])
}

model ServiceRequestAssignment {
  id               String    @id @default(cuid())
  serviceRequestId String
  assignedTo       String
  assignedBy       String
  role             String    @default("primary")
  assignedAt       DateTime  @default(now())
  acceptedAt       DateTime?
  declinedAt       DateTime?

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([assignedTo])
}

model ServiceRequestEscalation {
  id               String    @id @default(cuid())
  serviceRequestId String
  escalatedBy      String
  escalatedTo      String
  reason           String
  escalatedAt      DateTime  @default(now())
  resolvedAt       DateTime?

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
}

model ServiceRequestQuote {
  id               String      @id @default(cuid())
  serviceRequestId String
  submittedBy      String
  amount           Float
  scopeDescription String
  validUntil       DateTime?
  status           QuoteStatus @default(PENDING)
  rejectionReason  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId, status])
}

model SlaPolicy {
  id                          String   @id @default(cuid())
  name                        String
  serviceType                 String
  responseDeadlineMinutes     Int      @default(60)
  completionDeadlineMinutes   Int      @default(1440)
  escalationAfterMinutes      Int      @default(120)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([serviceType])
}

model ServiceProvider {
  id               String           @id @default(cuid())
  userId           String
  organizationId   String?
  category         ProviderCategory @default(LANDLORD_PREFERRED)
  status           ProviderStatus   @default(PENDING_APPROVAL)
  specializations  String[]
  coverageAreas    String[]
  bio              String?
  qrCodeUrl        String?
  verificationLevel String          @default("Unverified")
  trustScore       Float            @default(0)
  suspensionReason String?
  blacklistReason  String?
  suspendedAt      DateTime?
  blacklistedAt    DateTime?
  approvedAt       DateTime?
  approvedBy       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  auditLogs   ServiceProviderAuditLog[]
  performance ServiceProviderPerformance?

  @@index([organizationId, status])
  @@index([userId])
}

model ServiceProviderAuditLog {
  id           String   @id @default(cuid())
  providerId   String
  action       String
  fromStatus   String?
  toStatus     String?
  reason       String?
  reviewedBy   String
  createdAt    DateTime @default(now())

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt])
}

model ServiceProviderPerformance {
  id                     String   @id @default(cuid())
  providerId             String   @unique
  responseTimeSec        Float    @default(0)
  completionTimeSec      Float    @default(0)
  disputeRate            Float    @default(0)
  reassignmentRate       Float    @default(0)
  cancellationRate       Float    @default(0)
  reworkRate             Float    @default(0)
  totalJobsCompleted     Int      @default(0)
  updatedAt              DateTime @updatedAt

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model OutboxEvent {
  id               String    @id @default(cuid())
  eventType        String
  payload          Json
  processed        Boolean   @default(false)
  retryCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  processedAt      DateTime?
  serviceRequestId String?

  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([processed, createdAt])
  @@index([eventType])
}

model CustomTypeDefinition {
  id             String   @id @default(cuid())
  name           String   @unique
  metadataSchema Json
  serviceMode    ServiceMode @default(MANAGED)
  defaultPriority SrPriority @default(NORMAL)
  slaPolicyId    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ServiceTypeConfig {
  id                        String   @id @default(cuid())
  serviceType               String   @unique
  quoteRequired             Boolean  @default(false)
  supervisorApprovalRequired Boolean @default(false)
  evidenceRequirements      String[]
  assignmentRestrictions    String   @default("open")
  escrowRules               String?
  slaPolicyId               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// ─── Subscription Package ─────────────────────────────────────────────────────

model Package {
  id                       String      @id @default(cuid())
  name                     String      @unique
  tier                     PackageTier @unique
  listingSlots             Int
  hasServiceRequests       Boolean     @default(true)
  serviceRequestMonthlyLimit Int?      // null = unlimited; 0 = blocked
  monthlyPriceKes          Decimal     @default(0)
  isListingOnly            Boolean     @default(false)
  annualDiscountEligible   Boolean     @default(true)
  overageSlotFeeKes        Decimal     @default(150)
  isActive                 Boolean     @default(true)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  userSubscriptions UserPackageSubscription[]
}

model UserPackageSubscription {
  id             String      @id @default(cuid())
  userId         String
  organizationId String?
  packageId      String
  status         String      @default("active") // active, cancelled, expired
  billingCycle   String      @default("monthly") // monthly, annual
  startedAt      DateTime    @default(now())
  nextBillingAt  DateTime?
  canceledAt     DateTime?
  srUsedThisMonth Int        @default(0)
  srCounterResetAt DateTime  @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  package Package @relation(fields: [packageId], references: [id])

  @@index([userId, status])
  @@index([organizationId])
}

// ─── Account Freeze & Appeals ─────────────────────────────────────────────────

model AccountFreeze {
  id            String       @id @default(cuid())
  userId        String
  freezeType    FreezeType
  status        FreezeStatus @default(ACTIVE)
  reason        String
  requiredAction String?
  appliedBy     String       // admin user id or "system"
  appliedAt     DateTime     @default(now())
  liftedAt      DateTime?
  liftedBy      String?
  liftReason    String?
  notifiedAt    DateTime?
  createdAt     DateTime     @default(now())

  user    AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  appeals FreezeAppeal[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model FreezeAppeal {
  id          String       @id @default(cuid())
  freezeId    String
  userId      String
  reason      String
  evidenceUrls String[]
  status      AppealStatus @default(SUBMITTED)
  submittedAt DateTime     @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  decisionReason String?
  isSecondAppeal Boolean   @default(false)

  freeze AccountFreeze @relation(fields: [freezeId], references: [id], onDelete: Cascade)
  user   AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([freezeId])
  @@index([userId, status])
}

// ─── Blacklist ────────────────────────────────────────────────────────────────

model BlacklistEntry {
  id               String   @id @default(cuid())
  nationalIdHash   String?
  phoneNumbers     String[]
  emailAddresses   String[]
  deviceFingerprints String[]
  reason           String
  evidenceLinks    String[]
  addedBy          String
  addedAt          DateTime @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?

  @@index([nationalIdHash])
}

// ─── Admin Document Requests ──────────────────────────────────────────────────

model UserDocumentRequest {
  id               String                     @id @default(cuid())
  userId           String
  requestedBy      String
  documentType     String
  description      String?
  deadline         DateTime?
  enforcement      DocumentRequestEnforcement @default(REMINDER)
  status           DocumentRequestStatus      @default(PENDING)
  uploadedDocUrl   String?
  uploadedAt       DateTime?
  reviewedAt       DateTime?
  reviewedBy       String?
  rejectionReason  String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, deadline])
}

// ─── Utility Management ───────────────────────────────────────────────────────

model UtilityMeter {
  id           String       @id @default(cuid())
  unitId       String
  meterNumber  String
  type         UtilityType
  billingModel BillingModel @default(FLAT_RATE)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  readings UtilityReading[]

  @@index([unitId, isActive])
}

model UtilityReading {
  id               String        @id @default(cuid())
  meterId          String
  readingDate      DateTime
  previousReading  Float
  currentReading   Float
  consumption      Float
  flatRateAmountKes Float?
  imageUrl         String?
  createdBy        String
  isDisputed       Boolean       @default(false)
  disputeStatus    DisputeStatus?
  originalReadingId String?      // set on revision records
  revisionReason   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  meter    UtilityMeter     @relation(fields: [meterId], references: [id], onDelete: Cascade)
  disputes UtilityDispute[]

  @@index([meterId, readingDate])
}

model ServiceCharge {
  id               String           @id @default(cuid())
  propertyId       String
  name             String
  allocationMethod AllocationMethod @default(PRO_RATA)
  amountKes        Decimal?         // required when FLAT_AMOUNT
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([propertyId, isActive])
}

model UtilityDispute {
  id              String        @id @default(cuid())
  readingId       String
  raisedByUserId  String
  reason          String
  status          DisputeStatus @default(OPEN)
  landlordResponse String?
  landlordRespondedAt DateTime?
  adminDecision   String?
  adminDecidedAt  DateTime?
  adminDecidedBy  String?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reading UtilityReading @relation(fields: [readingId], references: [id], onDelete: Cascade)

  @@index([readingId, status])
}

// ─── Deposit Transfer ─────────────────────────────────────────────────────────

model DepositTransfer {
  id                  String                @id @default(cuid())
  leaseId             String
  outgoingTenantId    String
  propertyId          String
  unitId              String
  depositAmountKes    Decimal
  platformFeeKes      Decimal               @default(500)
  incomingTenantId    String?
  status              DepositTransferStatus @default(LISTED)
  listedAt            DateTime              @default(now())
  buyerPaidAt         DateTime?
  landlordApprovedAt  DateTime?
  inspectionCompletedAt DateTime?
  releasedAt          DateTime?
  expiresAt           DateTime
  cancelledAt         DateTime?
  escrowAccountId     String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([outgoingTenantId, status])
  @@index([unitId, status])
  @@index([status, expiresAt])
}
