# Canonical URL for SEO, sitemap, Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WhatsApp click-to-chat (digits only, country code included, no +)
# Example Kenya: 254712345678
NEXT_PUBLIC_WHATSAPP_E164=254700000000

# Shown in mailto: CTAs for valuation & consultation
NEXT_PUBLIC_CONSULTATION_EMAIL=hello@secureliving.com

# Backend API origin for local split setup
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:4000
