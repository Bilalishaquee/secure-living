    ]
  },

  "rbac": {
    "description": "Role-Based Access Control — full permission matrix for the platform",
    "roles": [
      {
        "id": "super_admin",
        "name": "Super Admin",
        "scope": "Global — all organizations, all branches",
        "description": "Full platform control. Anthropic/SaaS operator level.",
        "permissions": ["*"]
      },
      {
        "id": "admin",
        "name": "Organization Admin",
        "scope": "Organization-wide",
        "description": "Manages their own organization, branches, users, and all data within.",
        "permissions": [
          "org:manage", "branch:create", "branch:manage", "user:invite", "user:assign_role",
          "property:create", "property:edit", "property:delete", "property:view",
          "unit:create", "unit:edit", "unit:view",
          "tenant:create", "tenant:edit", "tenant:view", "tenant:offboard",
          "lease:create", "lease:edit", "lease:view", "lease:terminate",
          "finance:view", "finance:approve", "finance:export",
          "report:view_all", "report:export",
          "maintenance:create", "maintenance:assign", "maintenance:close",
          "kyc:approve", "kyc:reject",
          "audit:view"
        ]
      },
      {
        "id": "branch_manager",
        "name": "Branch Manager",
        "scope": "Branch-scoped",
        "description": "Manages properties and tenants within their assigned branch only.",
        "permissions": [
          "property:create", "property:edit", "property:view",
          "unit:create", "unit:edit", "unit:view",
          "tenant:create", "tenant:edit", "tenant:view",
          "lease:create", "lease:edit", "lease:view",
          "finance:view", "finance:submit",
          "maintenance:create", "maintenance:assign",
          "report:view_branch",
          "user:view_branch"
        ]
      },
      {
        "id": "landlord",
        "name": "Landlord / Property Owner",
        "scope": "Own properties only",
        "description": "Independent landlord who owns and manages their own properties.",
        "permissions": [
          "property:create", "property:edit", "property:view_own",
          "unit:create", "unit:edit", "unit:view_own",
          "tenant:create", "tenant:edit", "tenant:view_own",
          "lease:create", "lease:edit", "lease:view_own",
          "finance:view_own", "finance:submit",
          "rent_collection:manage",
          "maintenance:create", "maintenance:view_own",
          "report:view_own",
          "document:upload", "document:esign"
        ]
      },
      {
        "id": "property_manager",
        "name": "Property Manager",
        "scope": "Delegated properties only",
        "description": "Third-party manager acting on behalf of a landlord for specific properties.",
        "permissions": [
          "property:view_delegated", "property:edit_delegated",
          "unit:view_delegated",
          "tenant:create", "tenant:edit", "tenant:view_delegated",
          "lease:create", "lease:edit",
          "maintenance:create", "maintenance:assign",
          "finance:view_delegated", "finance:submit",
          "report:view_delegated"
        ]
      },
      {
        "id": "tenant",
        "name": "Tenant / Resident",
        "scope": "Own tenancy only",
        "description": "Resident who can pay rent, submit requests, view their lease.",
        "permissions": [
          "rent:pay", "rent:view_history",
          "lease:view_own",
          "maintenance:create_own", "maintenance:view_own",
          "document:view_own",
          "profile:edit_own",
          "screening:complete"
        ]
      },
      {
        "id": "professional",
        "name": "Professional / Service Provider",
        "scope": "Assigned jobs only",
        "description": "Plumber, electrician, cleaner, etc. Can view assigned work orders.",
        "permissions": [
          "maintenance:view_assigned",
          "maintenance:update_assigned",
          "quote:submit",
          "invoice:submit",
          "profile:edit_own"
        ]
      },
      {
        "id": "accountant",
        "name": "Accountant / CPA",
        "scope": "Financial read-only for assigned org",
        "description": "External accountant with read-only access to financials and reports.",
        "permissions": [
          "finance:view", "report:view_all", "report:export",
          "transaction:view", "document:view_financial"
        ]
      },
      {
        "id": "staff",
        "name": "Staff Member",
        "scope": "Limited — assigned tasks",
        "description": "Support staff with limited operational access.",
        "permissions": [
          "tenant:view", "maintenance:view", "maintenance:update",
          "property:view"
        ]
      }
    ],
    "permission_enforcement": {
      "api_middleware": "Every API route checks: (1) JWT validity, (2) role permission, (3) branch/org scope, (4) resource ownership",
      "branch_isolation": "A branch_manager cannot see or modify data outside their branch_id",
      "audit_log": "All write actions (create/update/delete) are appended to immutable audit_logs table with user_id, role, action, timestamp, before/after JSON"
    }
  },

  "modules": {

    "module_01_auth_identity": {
      "phase": 1,
      "name": "Authentication, Identity & Organization",
      "priority": "CRITICAL — Must be built first",
      "budget_usd": 500,
      "timeline_weeks": "2–3",
      "description": "The security bedrock. Nothing else works without this.",
      "sub_modules": {
        "user_registration": {
          "fields": ["full_name", "email", "phone_number (Kenya +254)", "password", "role_requested", "organization_id (optional)", "referral_code"],
          "phone_verification": "OTP via SMS (Africa's Talking or Twilio Kenya)",
          "email_verification": "Email link",
          "kyc_upload": ["national_id_front", "national_id_back", "kra_pin_certificate", "selfie_with_id"],
          "kyc_status": ["pending", "under_review", "approved", "rejected"]
        },
        "authentication": {
          "method": "JWT (Access + Refresh tokens)",
          "access_token_expiry": "15 minutes",
          "refresh_token_expiry": "30 days",
          "mfa": "OTP via SMS or TOTP (Google Authenticator)",
          "social_login": ["Google OAuth2"],
          "session_management": "Redis-backed session store",
          "password_policy": "Min 8 chars, 1 uppercase, 1 number, 1 special"
        },
        "organization_model": {
          "types": ["Independent Landlord", "Property Management Agency", "Diaspora Client", "SACCO/Co-op"],
          "fields": ["org_id", "name", "type", "country", "county", "logo", "subscription_plan", "owner_user_id", "created_at"],
          "branch_model": {
            "fields": ["branch_id", "org_id", "name", "county", "manager_user_id", "is_active"],
            "note": "A branch is a geographic or operational subdivision of an organization (e.g., Nairobi Branch, Mombasa Branch)"
          }
        },
        "rbac_engine": {
          "description": "See RBAC section above for full permission matrix",
          "middleware": "checkPermission(permission_key) middleware on every protected route",
          "scope_injection": "branch_id and org_id injected into every DB query to enforce isolation"
        },
        "audit_log": {
          "table": "audit_logs",
          "fields": ["id", "user_id", "role", "action", "resource_type", "resource_id", "branch_id", "org_id", "ip_address", "user_agent", "before_json", "after_json", "timestamp"],
          "immutable": true,
          "note": "No UPDATE or DELETE ever on this table. Append-only."
        }
      },
      "api_endpoints": [
        "POST /auth/register",
        "POST /auth/login",
        "POST /auth/logout",
        "POST /auth/refresh-token",
        "POST /auth/verify-email",
        "POST /auth/verify-phone",
        "POST /auth/forgot-password",
        "POST /auth/reset-password",
        "POST /auth/mfa/enable",
        "POST /auth/mfa/verify",
        "GET  /users/me",
        "PUT  /users/me",
        "POST /organizations",
        "GET  /organizations/:id",
        "POST /organizations/:id/branches",
        "GET  /organizations/:id/branches",
        "POST /users/invite",
        "GET  /roles",
        "PUT  /users/:id/role",
        "GET  /audit-logs"
      ]
    },

    "module_02_property_units": {
      "phase": 2,
      "name": "Property, Units & Ownership Graph",
      "priority": "HIGH",
      "budget_usd": 500,
      "timeline_weeks": "2–3",
      "description": "The asset truth layer — every property and unit in the system.",
      "sub_modules": {
        "property": {
          "fields": [
            "property_id", "org_id", "branch_id", "owner_user_id", "manager_user_id",
            "name", "property_type", "address_line1", "address_line2", "county",
            "sub_county", "ward", "gps_latitude", "gps_longitude",
            "land_reference_number", "title_deed_number", "year_built",
            "total_units", "purchase_price_kes", "current_value_kes",
            "mortgage_balance_kes", "tags", "status", "created_at", "updated_at"
          ],
          "property_types": ["Apartment Block", "Maisonette", "Bungalow", "Bedsitter", "Studio", "Commercial", "Mixed Use", "Short-Term Rental", "Airbnb"],
          "media": ["photos[]", "videos[]", "floor_plan_url", "title_deed_scan_url"],
          "ownership_types": ["Owned", "Managed (Third Party)", "Joint Ownership", "Company Owned"]
        },
        "unit": {
          "fields": [
            "unit_id", "property_id", "unit_number", "floor", "unit_type",
            "bedrooms", "bathrooms", "size_sqft", "rent_amount_kes",
            "deposit_amount_kes", "is_furnished", "amenities[]",
            "status", "current_tenant_id", "current_lease_id"
          ],
          "unit_statuses": ["vacant", "occupied", "under_maintenance", "reserved", "unavailable"],
          "unit_types": ["Bedsitter", "1BR", "2BR", "3BR", "4BR+", "Studio", "Penthouse", "Commercial Unit", "Shop"]
        },
        "ownership_graph": {
          "description": "Maps who owns, manages, or caretakes each property — supports complex structures",
          "table": "property_roles",
          "fields": ["id", "property_id", "user_id", "role", "scope", "start_date", "end_date", "commission_rate"],
          "roles": ["owner", "manager", "caretaker", "co_owner", "agent"]
        }
      },
      "api_endpoints": [
        "POST   /properties",
        "GET    /properties",
        "GET    /properties/:id",
        "PUT    /properties/:id",
        "DELETE /properties/:id",
        "POST   /properties/:id/units",
        "GET    /properties/:id/units",
        "GET    /units/:id",
        "PUT    /units/:id",
        "DELETE /units/:id",
        "POST   /properties/:id/media",
        "GET    /properties/:id/media",
        "POST   /properties/:id/roles",
        "GET    /properties/:id/roles"
      ]
    },

    "module_03_service_requests": {
      "phase": 3,
      "name": "Service Request Engine (Polymorphic Core)",
      "priority": "HIGH",
      "budget_usd": 500,
      "timeline_weeks": "2–3",
      "description": "One unified engine for all service workflows — maintenance, inspections, legal, proxies.",
      "sub_modules": {
        "service_request": {
          "table": "service_requests",
          "fields": [
            "id", "org_id", "branch_id", "property_id", "unit_id",
            "requester_user_id", "assigned_to_user_id", "type",
            "title", "description", "priority", "status",
            "scheduled_date", "completed_date",
            "estimated_cost_kes", "actual_cost_kes",
            "evidence_urls[]", "notes", "created_at", "updated_at"
          ],
          "types": ["maintenance", "inspection", "proxy_payment", "legal", "cleaning", "renovation", "emergency"],
          "statuses": ["draft", "submitted", "approved", "assigned", "in_progress", "pending_review", "completed", "cancelled", "disputed"],
          "priorities": ["low", "medium", "high", "emergency"],
          "state_machine_transitions": {
            "draft": ["submitted"],
            "submitted": ["approved", "cancelled"],
            "approved": ["assigned", "cancelled"],
            "assigned": ["in_progress"],
            "in_progress": ["pending_review", "completed"],
            "pending_review": ["completed", "in_progress"],
            "completed": [],
            "cancelled": [],
            "disputed": ["in_progress", "cancelled"]
          }
        },
        "maintenance": {
          "extends": "service_request",
          "extra_fields": ["maintenance_category", "vendor_id", "quote_id", "work_order_number", "before_photos[]", "after_photos[]"],
          "maintenance_categories": ["Plumbing", "Electrical", "Structural", "Painting", "Pest Control", "Security", "Cleaning", "HVAC", "Other"]
        },
        "inspection": {
          "extends": "service_request",
          "extra_fields": ["inspection_type", "inspector_id", "checklist_json", "overall_condition", "report_url"],
          "inspection_types": ["move_in", "move_out", "routine", "emergency", "pre_purchase"]
        },
        "evidence_uploads": {
          "table": "service_evidence",
          "fields": ["id", "service_request_id", "uploader_user_id", "file_url", "file_type", "caption", "uploaded_at"],
          "file_types": ["photo", "video", "document", "audio"]
        }
      },
      "api_endpoints": [
        "POST   /service-requests",
        "GET    /service-requests",
        "GET    /service-requests/:id",
        "PUT    /service-requests/:id",
        "PATCH  /service-requests/:id/status",
        "POST   /service-requests/:id/evidence",
        "POST   /service-requests/:id/assign",
        "POST   /service-requests/:id/escalate",
        "GET    /properties/:id/service-requests",
        "GET    /units/:id/service-requests"
      ]
    },

    "module_04_wallets_ledgers": {
      "phase": 4,
      "name": "Wallets, Ledgers & Immutable Transactions",
      "priority": "CRITICAL — Must come before rent collection",
      "budget_usd": 500,
      "timeline_weeks": "3",
      "description": "The financial spine of the platform. All money flows through this.",
      "sub_modules": {
        "wallets": {
          "table": "wallets",
          "fields": ["id", "owner_id", "owner_type", "wallet_type", "currency", "balance_kes", "is_frozen", "created_at"],
          "wallet_types": ["user_wallet", "property_wallet", "escrow_wallet", "reserve_wallet", "operating_wallet"],
          "owner_types": ["user", "property", "organization"],
          "note": "balance_kes is DERIVED — computed from ledger entries, never stored as mutable field"
        },
        "ledger": {
          "table": "ledger_entries",
          "fields": [
            "id", "wallet_id", "transaction_id", "entry_type",
            "amount_kes", "running_balance_kes", "description",
            "reference_id", "reference_type", "created_at"
          ],
          "entry_types": ["credit", "debit"],
          "reference_types": ["rent_payment", "deposit", "maintenance_payout", "refund", "reversal", "fee", "commission"]
        },
        "transactions": {
          "table": "transactions",
          "fields": [
            "id", "org_id", "property_id", "unit_id",
            "from_wallet_id", "to_wallet_id",
            "amount_kes", "fee_kes", "net_kes",
            "transaction_type", "payment_method",
            "mpesa_reference", "bank_reference", "idempotency_key",
            "status", "description", "metadata_json",
            "created_at", "reversed_at", "reversal_transaction_id"
          ],
          "transaction_types": ["rent_payment", "deposit", "deposit_refund", "maintenance_payment", "commission", "fee", "reversal", "withdrawal", "top_up"],
          "payment_methods": ["mpesa_stk", "mpesa_paybill", "mpesa_till", "airtel_money", "bank_transfer_rtgs", "bank_transfer_eft", "pesalink", "card", "cash"],
          "immutability_rules": {
            "no_update_on_transactions": true,
            "no_delete_on_transactions": true,
            "reversal_only": "To undo a transaction, create a reversal transaction that references the original",
            "double_entry": "Every credit to one wallet must have a corresponding debit to another"
          }
        },
        "sub_ledgers": {
          "types": ["rent_ledger", "deposit_ledger", "escrow_ledger", "reserve_ledger", "maintenance_ledger"],
          "note": "Each sub-ledger rolls up to the main ledger for reconciliation"
        },
        "mpesa_integration": {
          "provider": "Safaricom Daraja API",
          "flows": ["STK Push (C2B)", "B2C (payouts to landlords/vendors)", "Paybill", "Buy Goods (Till)"],
          "webhook": "POST /webhooks/mpesa/confirmation",
          "idempotency": "mpesa_reference must be unique — duplicate callbacks ignored"
        }
      },
      "api_endpoints": [
        "GET    /wallets/:id/balance",
        "GET    /wallets/:id/ledger",
        "POST   /transactions",
        "GET    /transactions/:id",
        "GET    /transactions?property_id=&type=&from=&to=",
        "POST   /transactions/:id/reverse",
        "GET    /properties/:id/financial-summary",
        "POST   /webhooks/mpesa/confirmation",
        "POST   /webhooks/mpesa/validation"
      ]
    },

    "module_05_escrow": {
      "phase": 5,
      "name": "Escrow State Machine & Holds",
      "priority": "CRITICAL — before rent collection",
      "budget_usd": 500,
      "timeline_weeks": "2–3",
      "description": "Prevents fraud, double spend, and premature payouts.",
      "sub_modules": {
        "escrow_accounts": {
          "table": "escrow_accounts",
          "fields": ["id", "lease_id", "tenant_id", "landlord_id", "property_id", "unit_id", "amount_kes", "status", "held_at", "released_at", "dispute_id", "created_at"],
          "statuses": ["pending", "held", "partially_released", "fully_released", "disputed", "refunded", "forfeited"],
          "state_transitions": {
            "pending": ["held"],
            "held": ["partially_released", "fully_released", "disputed"],
            "partially_released": ["fully_released", "disputed"],
            "disputed": ["held", "fully_released", "refunded"],
            "fully_released": [],
            "refunded": [],
            "forfeited": []
          }
        },
        "holds": {
          "table": "fund_holds",
          "fields": ["id", "wallet_id", "amount_kes", "reason", "held_by_user_id", "released_by_user_id", "is_active", "held_at", "released_at"],
          "reasons": ["pending_verification", "dispute", "fraud_investigation", "contract_obligation"]
        },
        "idempotency": {
          "table": "idempotency_keys",
          "fields": ["key", "request_hash", "response_json", "created_at", "expires_at"],
          "note": "All payment API calls must include X-Idempotency-Key header. Duplicate calls return cached response."
        }
      },
      "api_endpoints": [
        "POST   /escrow",
        "GET    /escrow/:id",
        "PATCH  /escrow/:id/hold",
        "PATCH  /escrow/:id/release",
        "PATCH  /escrow/:id/dispute",
        "GET    /escrow?lease_id=",
        "POST   /fund-holds",
        "DELETE /fund-holds/:id"
      ]
    },

    "module_06_rent_collection": {
      "phase": 6,
      "name": "Rent Collection & Reconciliation",
      "priority": "HIGH",
      "budget_usd": 500,
      "timeline_weeks": "2–3",
      "description": "Money enters the system safely. Automated reconciliation catches mismatches.",
      "sub_modules": {
        "rent_invoices": {
          "table": "rent_invoices",
          "fields": [
            "id", "lease_id", "tenant_id", "landlord_id", "property_id", "unit_id",
            "invoice_number", "period_start", "period_end", "due_date",
            "rent_amount_kes", "late_fee_kes", "other_charges_kes",
            "total_due_kes", "amount_paid_kes", "balance_kes",
            "status", "payment_method", "mpesa_reference",
            "sent_at", "paid_at", "created_at"
          ],
          "statuses": ["draft", "sent", "partially_paid", "paid", "overdue", "waived", "disputed"],
          "auto_generation": "Invoices auto-generated monthly based on lease terms on the 1st of each month"
        },
        "payment_methods_kenya": {
          "mpesa_stk_push": {
            "description": "Prompt tenant's phone to pay via M-Pesa",
            "api": "Safaricom Daraja STK Push",
            "flow": "Landlord/system initiates → tenant gets popup on phone → tenant enters PIN → confirmation webhook"
          },
          "mpesa_paybill": {
            "description": "Tenant manually pays to paybill number with account reference",
            "account_format": "Unit number or lease ID used as account reference"
          },
          "bank_transfer": "EFT / RTGS for larger amounts",
          "cash": "Recorded manually by manager/caretaker with receipt upload"
        },
        "late_fees": {
          "config_per_lease": true,
          "types": ["fixed_amount", "percentage_of_rent"],
          "grace_period_days": "Configurable per property (default 5 days)",
          "auto_charge": "Auto-charged at midnight on grace period expiry"
        },
        "automated_reminders": {
          "channels": ["SMS (Africa's Talking)", "Email", "WhatsApp (optional)"],
