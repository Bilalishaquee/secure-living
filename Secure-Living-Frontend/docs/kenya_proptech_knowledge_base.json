  "database_schema_overview": {
    "core_tables": [
      "users", "organizations", "branches", "user_roles",
      "properties", "units", "property_roles", "property_media",
      "leases", "lease_renewals",
      "tenant_applications", "listings",
      "service_requests", "service_evidence",
      "wallets", "ledger_entries", "transactions",
      "escrow_accounts", "fund_holds", "idempotency_keys",
      "rent_invoices", "reconciliation_reports",
      "deposit_records",
      "professionals", "quotes", "job_milestones", "job_reviews", "clawback_requests",
      "expenses", "expense_categories",
      "feedback", "risk_items", "sops",
      "leads", "campaigns",
      "audit_logs",
      "notifications", "notification_templates",
      "documents", "esign_envelopes",
      "kyc_documents",
      "screening_reports"
    ],
    "key_relationships": {
      "property → units": "One-to-many",
      "property → leases (via unit)": "One-to-many",
      "lease → tenant (user)": "Many-to-one",
      "lease → deposit_record": "One-to-one",
      "lease → rent_invoices": "One-to-many",
      "service_request → evidence": "One-to-many",
      "service_request → quote → milestones": "One-to-many",
      "wallet → ledger_entries": "One-to-many",
      "transaction → ledger_entries (debit + credit)": "One-to-two",
      "escrow_account → lease": "One-to-one",
      "user → wallets": "One-to-many"
    }
  },

  "tech_stack_recommendation": {
    "frontend": "Already built — React/Next.js (existing)",
    "backend": "Node.js + Express.js or NestJS (TypeScript)",
    "database": "PostgreSQL (primary) + Redis (cache/queues)",
    "orm": "Prisma",
    "auth": "JWT + bcrypt + passport.js",
    "file_storage": "AWS S3 or Cloudflare R2",
    "payments": "Safaricom Daraja API (M-Pesa), Stripe (cards)",
    "sms": "Africa's Talking (SMS/USSD)",
    "email": "Resend or SendGrid",
    "whatsapp": "Africa's Talking WhatsApp API or Twilio",
    "job_queue": "Bull + Redis",
    "search": "PostgreSQL full-text search (start) → Elasticsearch (scale)",
    "testing": "Jest + Supertest",
    "ci_cd": "GitHub Actions",
    "hosting": "AWS (EC2/ECS) or Railway.app or Render.com",
    "monitoring": "Sentry + Datadog"
  },

  "kenya_specific_adaptations": {
    "payments": {
      "primary_method": "M-Pesa (80%+ of Kenyans use mobile money)",
      "secondary": "Bank transfer, Airtel Money, PesaLink",
      "no_support_needed": "ACH (US only), checks"
    },
    "identity_verification": {
      "primary_id": "National ID (Huduma Namba)",
      "business_id": "Certificate of Incorporation + KRA PIN",
      "crb": "TransUnion Kenya, Creditinfo, Metropol (replace US credit bureaus)"
    },
    "legal_framework": [
      "Rent Restriction Act (Cap 296) — limits rent increases for controlled premises",
      "Land Registration Act 2012",
      "The Law of Contract Act",
      "Landlord and Tenant (Shops, Hotels and Catering Establishments) Act",
      "Data Protection Act 2019",
      "Kenya Information and Communications Act (eSignatures)"
    ],
    "tax_obligations": {
      "monthly_rental_income_tax": "10% WHT on gross rent (residential) — remit to KRA by 20th of following month",
      "itax_filing": "Monthly MRI returns + annual income tax return",
      "vat": "16% on commercial property rentals above KES 5M annual turnover threshold"
    },
    "county_structure": {
      "note": "Kenya has 47 counties. Branch/property should be county-tagged.",
      "major_rental_markets": ["Nairobi", "Mombasa", "Kisumu", "Nakuru", "Eldoret", "Thika", "Kiambu"]
