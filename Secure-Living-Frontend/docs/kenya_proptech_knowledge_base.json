{
  "meta": {
    "platform_name": "SecureLiving Kenya",
    "version": "1.0.0",
    "inspired_by": "Stessa.com (USA) — adapted for Kenya market",
    "target_market": "Kenya",
    "currency": "KES (Kenyan Shilling)",
    "payment_rails": ["M-Pesa", "Airtel Money", "Bank Transfer (RTGS/EFT)", "PesaLink"],
    "compliance": ["Kenya Revenue Authority (KRA)", "Rent Restriction Act (Kenya)", "Land Registration Act 2012", "Data Protection Act 2019 (Kenya)"],
    "language_support": ["en", "sw"],
    "description": "A full-stack property management and investment platform for Kenyan landlords, tenants, property managers, and professionals — inspired by Stessa.com but built for Kenya's unique market, payment infrastructure, and legal framework.",
    "client_requirement_doc": "12_phases_for_secure_living_system.docx",
    "total_phases": 12,
    "frontend_status": "COMPLETED — backend, APIs, and integrations to be built by Cursor"
  },

